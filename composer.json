{
  "name": "bearlord/yew-framework",
  "description": "A swoole distributed framework for network application",
  "type": "library",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "bearlord",
      "email": "565364226@qq.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "ackintosh/ganesha": "^1.0|^2.0|^3.0",
    "cebe/markdown": "^1.2.1",
    "doctrine/annotations": "^1.6",
    "doctrine/cache": "^1.5",
    "doctrine/orm": "^2.5",
    "ezyang/htmlpurifier": "^4.10.0",
    "friendsofphp/consul-php-sdk": ">=5.0.0",
    "filp/whoops": "^2.3",
    "guzzlehttp/guzzle": "^7.10.0",
    "inhere/php-validate": "^2.8",
    "illuminate/view": ">=5.8",
    "jakubledl/dissect": "~1.0",
    "malkusch/lock": "^3.0",
    "monolog/monolog": "^1.24",
    "nikic/php-parser": "^5.7.0",
    "ocramius/proxy-manager": "^2.1",
    "opis/closure": "^3.6",
    "php": "^8.0",
    "php-amqplib/php-amqplib": "^3.7.0",
    "php-di/php-di": "^7.1.0",
    "psr/http-message": "^1.0",
    "swlib/saber": "^1.0",
    "symfony/console": "^6.0",
    "symfony/finder": "^6.0",
    "symfony/var-dumper": "*",
    "symfony/yaml": "^6.0.0"
  },
  "require-dev": {
    "ext-ds": "*",
    "ext-intl": "*",
    "ext-libxml": "*",
    "ext-sockets": "*",
    "ext-json": "*",
    "ext-redis": "*",
    "ext-swoole": ">=6.1",
    "ext-pdo": "*",
    "ext-posix": "*",
    "ext-iconv": "*",
    "swoole/ide-helper": "^5.0",
    "symfony/process": "^6.0.0",
    "twig/twig": "^3.11.2"
  },
  "autoload": {
    "psr-4": {
      "Yew\\": "src"
    },
    "files": [
      "src/Core/Common.php",
      "src/Goaop/ParserReflection/bootstrap.php",
      "src/Nikic/FastRoute/bootstrap.php",
      "src/Plugins/MQTT/constants.php"
